# Distributed Search Engine Configuration
# Copy this file to .env and modify as needed.

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/

# Master server address
MASTER_IP=localhost:50051

# Backup server address
BACKUP_IP=localhost:50063

# Crawler server address
CRAWLER_IP=localhost:50060

# Path to the replicas list file
REPLICAS_LIST_FILE=replicas_list.txt
